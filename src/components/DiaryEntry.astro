---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { diarySlug } from '../lib/diary';

type Props = { entry: CollectionEntry<'diary'> };
const { entry } = Astro.props;
const { Content } = await render(entry);
const date = entry.data.date;
const href = `/diary/${diarySlug(entry)}/`;
---
<article class="entry">
  <span class="node" aria-hidden="true"></span>
  <a class="entry-link" href={href}>
    <time datetime={date.toISOString()}>
      {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
    </time>
    <div class="body">
      <Content />
    </div>
  </a>
</article>

<style>
  .entry {
    position: relative;
    padding-left: 28px;
    padding-bottom: 1.6rem;
  }
  .entry:last-child {
    padding-bottom: 0.5rem;
  }
  .node {
    position: absolute;
    left: 1px;
    top: 5px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--node);
    transition: border-color 0.2s ease;
  }
  .entry-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  time {
    display: block;
    margin-bottom: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .body :global(p) {
    margin: 0;
  }
  .body :global(p + p) {
    margin-top: 0.75rem;
  }
  .entry:hover .node {
    border-color: var(--accent);
  }
</style>
