---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      // Apply theme before paint to avoid a flash of the wrong colors.
      const saved = localStorage.getItem('theme');
      const system = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = saved ?? (system ? 'dark' : 'light');
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/diary/">Diary</a>
      <button id="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span class="moon">☾</span>
        <span class="sun">☀</span>
      </button>
    </header>
    <slot />
    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --text: #1f2328;
    --muted: #6b7280;
    --line: #e5e7eb;
    --spine: #d7dbe0;
    --node: #b4bac3;
    --accent: #4f46e5;
    --max-width: 640px;
  }
  :root[data-theme='dark'] {
    --bg: #11141a;
    --text: #e7e9ec;
    --muted: #9aa1ad;
    --line: #262b33;
    --spine: #2c323b;
    --node: #4a515c;
    --accent: #9b9df8;
  }
  * {
    box-sizing: border-box;
  }
  html {
    -webkit-text-size-adjust: 100%;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.65;
    transition: background 0.2s ease, color 0.2s ease;
  }
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1.25rem 4rem;
  }
  a {
    color: inherit;
  }

  /* Header + theme toggle */
  .site-header {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--text);
  }
  #theme-toggle {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    font-size: 0.95rem;
    line-height: 1;
    color: var(--text);
    background: none;
    border: 1px solid var(--line);
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  #theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  #theme-toggle .sun {
    display: none;
  }
  [data-theme='dark'] #theme-toggle .sun {
    display: inline;
  }
  [data-theme='dark'] #theme-toggle .moon {
    display: none;
  }

  /* Diary timeline — global so client-injected DOM is styled */
  .loading,
  .empty {
    color: var(--muted);
    font-size: 0.95rem;
  }
  .timeline {
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 4px;
    width: 2px;
    background: var(--spine);
  }
  .month {
    margin-bottom: 2rem;
  }
  .month:last-child {
    margin-bottom: 0;
  }
  .month-label {
    position: relative;
    margin: 0 0 1.1rem;
    padding-left: 28px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .entry {
    position: relative;
    padding-left: 28px;
    padding-bottom: 1.6rem;
    scroll-margin-top: 2rem;
  }
  .entry:last-child {
    padding-bottom: 0.5rem;
  }
  .entry .node {
    position: absolute;
    left: 1px;
    top: 5px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--node);
    transition: border-color 0.2s ease;
  }
  .entry .entry-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .entry time {
    display: block;
    margin-bottom: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted);
  }
  .entry .body p {
    margin: 0;
  }
  .entry .body p + p {
    margin-top: 0.75rem;
  }
  .entry:hover .node,
  .entry:focus-within .node {
    border-color: var(--accent);
  }

  /* Inline edit/delete tools (edit mode on the diary page) */
  .entry-tools {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.4rem;
  }
  .entry-tools button {
    font: inherit;
    font-size: 0.78rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    color: var(--muted);
    cursor: pointer;
  }
  .entry-tools button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .entry-tools button.delbtn:hover {
    color: #b91c1c;
    border-color: #b91c1c;
  }

  /* Entry head: date + per-entry link button */
  .entry-head {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.3rem;
  }
  .entry-head time {
    margin-bottom: 0;
  }
  .linkbtn {
    margin-left: auto;
    font: inherit;
    font-size: 0.78rem;
    color: var(--muted);
    background: none;
    border: none;
    padding: 0 0.2rem;
    cursor: pointer;
    opacity: 0.55;
    transition: color 0.2s ease, opacity 0.2s ease;
  }
  .linkbtn:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* Deep-link highlight */
  .entry {
    transition: background-color 0.3s ease;
  }
  .entry.flash {
    background: rgba(79, 70, 229, 0.07);
    border-radius: 8px;
  }
  :root[data-theme='dark'] .entry.flash {
    background: rgba(155, 157, 248, 0.1);
  }
  .entry.flash .node {
    border-color: var(--accent);
  }
</style>
